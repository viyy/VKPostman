<UserControl x:Class="VkPostman.Wpf.Views.DraftsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:DraftsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ====== Draft list ====== -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Drafts" Style="{StaticResource SectionHeader}" />
                    <Button Content="📝 New draft"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding NewDraftCommand}"
                            Margin="0,0,0,8" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Drafts}"
                         SelectedItem="{Binding CurrentDraft, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='MMM d, HH:mm'}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ====== Editor ====== -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,0,12,0">
            <StackPanel>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Draft details" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="💾 Save"
                                        Style="{StaticResource PrimaryButton}"
                                        Margin="0,0,8,0"
                                        Command="{Binding SaveDraftCommand}"
                                        IsEnabled="{Binding CurrentDraft, Converter={x:Static vm:NotNullConverter.Instance}}" />
                                <Button Content="🗑 Delete"
                                        Style="{StaticResource OutlineButton}"
                                        Command="{Binding DeleteDraftCommand}"
                                        IsEnabled="{Binding CurrentDraft, Converter={x:Static vm:NotNullConverter.Instance}}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="Title" Margin="0,8,0,4" />
                        <TextBox Text="{Binding CurrentDraft.Title, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Common text (rendered via {{ common_text }})" Margin="0,12,0,4" />
                        <TextBox Text="{Binding CurrentDraft.CommonText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="100"
                                 VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="Theme tags (space-separated, common to all groups)" Margin="0,12,0,4" />
                        <TextBox Text="{Binding ThemeTagsInput, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Target groups" Style="{StaticResource SectionHeader}" />
                        <TextBlock Text="Groups without a template are disabled."
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,8" />
                        <ItemsControl ItemsSource="{Binding AllGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding HasTemplate}"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Group.DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock>
                                                <Run Text="@" /><Run Text="{Binding Group.ScreenName, Mode=OneWay}" />
                                                <Run Text=" · " /><Run Text="{Binding HasTemplateHint, Mode=OneWay}" />
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}"
                        Visibility="{Binding Placeholders.Count, Converter={x:Static vm:IntToVisibilityConverter.Instance}}">
                    <StackPanel>
                        <TextBlock Text="Placeholders (union across selected groups' templates)"
                                   Style="{StaticResource SectionHeader}" />
                        <ItemsControl ItemsSource="{Binding Placeholders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,6,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Text=" *" Foreground="#E64646"
                                                       Visibility="{Binding IsRequired, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}" />
                                            <TextBlock Text="  (" Margin="6,0,0,0" Style="{StaticResource MutedText}" />
                                            <TextBlock Text="{Binding TypeLabel, Mode=OneWay}" Style="{StaticResource MutedText}" />
                                            <TextBlock Text=")" Style="{StaticResource MutedText}" />
                                        </StackPanel>

                                        <!-- Single-field types: Text, VkLink, Url, TagList -->
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,3,0,0"
                                                 Visibility="{Binding IsSingleField, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}" />

                                        <!-- WikiLink: two side-by-side inputs -->
                                        <Grid Margin="0,3,0,0"
                                              Visibility="{Binding IsWikiLink, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="target (e.g. nelfias or club123)"
                                                           Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding WikiTarget, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="displayed text"
                                                           Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding WikiDisplay, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Style="{StaticResource MutedText}" Margin="0,3,0,0">
                                            <Run Text="used by: " /><Run Text="{Binding UsageHint, Mode=OneWay}" />
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ====== Per-group rendered output ====== -->
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Per-group output" Style="{StaticResource SectionHeader}" />

                <ItemsControl ItemsSource="{Binding PerGroupRenders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock Text="{Binding Group.DisplayName}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   DockPanel.Dock="Left" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Content="📋 Copy"
                                                    Style="{StaticResource OutlineButton}"
                                                    Margin="0,0,6,0"
                                                    Command="{Binding DataContext.CopyRenderedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="🌐 Open vk.com"
                                                    Style="{StaticResource OutlineButton}"
                                                    Command="{Binding DataContext.OpenGroupInBrowserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DockPanel>
                                    <TextBox Text="{Binding Rendered, Mode=OneWay}"
                                             IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             MaxHeight="260"
                                             Margin="0,8,0,0"
                                             Background="#F7F8FA"
                                             BorderThickness="0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="Pick one or more target groups to see each group's rendered post here."
                           Style="{StaticResource MutedText}"
                           Visibility="{Binding PerGroupRenders.Count, Converter={x:Static vm:ZeroToVisibilityConverter.Instance}}"
                           Margin="0,10,0,0" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
