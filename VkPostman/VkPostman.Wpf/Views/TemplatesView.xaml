<UserControl x:Class="VkPostman.Wpf.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:TemplatesViewModel}"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Template list ===== -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Templates" Style="{StaticResource SectionHeader}" />
                    <Button Content="📄 New template"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding NewTemplateCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Templates}"
                         SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <EventSetter Event="MouseDoubleClick" Handler="TemplateDoubleClick" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='MMM d, HH:mm'}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ===== Editor ===== -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <Grid>
                <TextBlock Text="Pick a template on the left, or click 'New template'."
                           Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsEditing, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}" />

                <ScrollViewer Visibility="{Binding IsEditing, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Template" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Autosave.Status, Converter={x:Static vm:AutosaveStatusLabelConverter.Instance}}"
                                           Foreground="{StaticResource VkTextSecondaryBrush}"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                                <Button Content="Close" Style="{StaticResource OutlineButton}"
                                        Command="{Binding CloseEditorCommand}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="Name" Margin="0,8,0,4" />
                        <TextBox Text="{Binding SelectedTemplate.Name, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Description" Margin="0,12,0,4" />
                        <TextBox Text="{Binding SelectedTemplate.Description, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4">
                            <Run Text="Body" FontWeight="SemiBold" />
                            <Run Text="— Scriban syntax. Placeholders you reference below auto-appear as rows." />
                        </TextBlock>
                        <TextBox x:Name="BodyTextBox"
                                 Text="{Binding BodyText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="160" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Mono, Consolas"
                                 SelectionChanged="BodyTextBox_SelectionChanged" />

                        <!-- ===== Chip toolbar — quick-add + autocomplete ===== -->
                        <ItemsControl ItemsSource="{Binding PlaceholderSuggestions}" Margin="0,6,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,2,4,2"
                                            Padding="8,2"
                                            Content="{Binding Display}"
                                            Command="{Binding DataContext.InsertPlaceholderCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Key}"
                                            ToolTip="{Binding Key}"
                                            FontFamily="Cascadia Mono, Consolas"
                                            FontSize="11"
                                            Background="{Binding IsGlobal,
                                                Converter={x:Static vm:GlobalChipBackgroundConverter.Instance}}"
                                            Foreground="{StaticResource VkTextBrush}"
                                            BorderBrush="{StaticResource VkBorderBrush}"
                                            BorderThickness="1"
                                            Cursor="Hand" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Style="{StaticResource MutedText}"
                                   Margin="0,2,0,0"
                                   Text="{Binding AutocompleteQuery,
                                                  Converter={x:Static vm:AutocompleteHintConverter.Instance}}" />

                        <TextBlock Text="Default theme tags" Margin="0,12,0,4" />
                        <TextBox Text="{Binding DefaultTagsInput, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Placeholders used" Style="{StaticResource SectionHeader}" Margin="0,16,0,4" />
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,0,0,6"
                                   Text="Derived from the Body. Edit definitions on the Placeholders tab — changes there propagate to every template using that key." />
                        <ItemsControl ItemsSource="{Binding UsedPlaceholders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource VkBorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="8" Margin="0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       FontFamily="Cascadia Mono, Consolas"
                                                       Margin="0,0,12,0">
                                                <Run Text="{}{{ " Foreground="#818C99" />
                                                <Run Text="{Binding Key, Mode=OneWay}" />
                                                <Run Text=" }}" Foreground="#818C99" />
                                            </TextBlock>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName, Mode=OneWay}"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Type, Mode=OneWay}"
                                                       Style="{StaticResource MutedText}"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Style="{StaticResource MutedText}" Margin="0,4,0,0"
                                   Text="No placeholders referenced yet. Type {{ my_key }} in the Body to add one."
                                   Visibility="{Binding UsedPlaceholders.Count, Converter={x:Static vm:ZeroToVisibilityConverter.Instance}}" />

                        <Button Content="🗑 Delete template"
                                Style="{StaticResource OutlineButton}"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0"
                                Foreground="#E64646"
                                BorderBrush="#E64646"
                                Command="{Binding DeleteTemplateCommand}"
                                CommandParameter="{Binding SelectedTemplate}"
                                Visibility="{Binding SelectedTemplate.Id, Converter={x:Static vm:IntToVisibilityConverter.Instance}}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
