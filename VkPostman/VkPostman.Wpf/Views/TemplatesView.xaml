<UserControl x:Class="VkPostman.Wpf.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:TemplatesViewModel}"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Template list ===== -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Templates" Style="{StaticResource SectionHeader}" />
                    <Button Content="📄 New template"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding NewTemplateCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Templates}"
                         SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <EventSetter Event="MouseDoubleClick" Handler="TemplateDoubleClick" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding UpdatedAt, StringFormat='MMM d, HH:mm'}"
                                           Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ===== Editor ===== -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <Grid>
                <TextBlock Text="Pick a template on the left, or click 'New template'."
                           Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsEditing, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}" />

                <ScrollViewer Visibility="{Binding IsEditing, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Template" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Autosave.Status, Converter={x:Static vm:AutosaveStatusLabelConverter.Instance}}"
                                           Foreground="{StaticResource VkTextSecondaryBrush}"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                                <Button Content="Close" Style="{StaticResource OutlineButton}"
                                        Command="{Binding CloseEditorCommand}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="Name" Margin="0,8,0,4" />
                        <TextBox Text="{Binding SelectedTemplate.Name, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Description" Margin="0,12,0,4" />
                        <TextBox Text="{Binding SelectedTemplate.Description, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,4">
                            <Run Text="Body" FontWeight="SemiBold" />
                            <Run Text="— Scriban syntax. Available globals: " />
                            <Run Text="{}{{ common_text }}, {{ group_tags }}, {{ theme_tags }}, {{ group_name }}" FontFamily="Consolas" />
                        </TextBlock>
                        <TextBox Text="{Binding SelectedTemplate.BodyTemplate, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="160" VerticalScrollBarVisibility="Auto"
                                 FontFamily="Cascadia Mono, Consolas" />

                        <TextBlock Text="Default theme tags" Margin="0,12,0,4" />
                        <TextBox Text="{Binding DefaultTagsInput, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Placeholders" Style="{StaticResource SectionHeader}" Margin="0,16,0,4" />
                        <ItemsControl ItemsSource="{Binding PlaceholderEditorItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource VkBorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="8" Margin="0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Key" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                                <TextBlock Text="Display name" Style="{StaticResource MutedText}" />
                                                <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Bottom">
                                                <TextBlock Text="Type" Style="{StaticResource MutedText}" />
                                                <ComboBox ItemsSource="{Binding DataContext.PlaceholderTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          SelectedItem="{Binding Type, Mode=TwoWay}"
                                                          MinWidth="120" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="3"
                                                      Content="Required"
                                                      VerticalAlignment="Bottom"
                                                      IsChecked="{Binding IsRequired}"
                                                      Margin="0,0,8,6" />
                                            <Button Grid.Column="4" Content="🗑"
                                                    Style="{StaticResource OutlineButton}"
                                                    VerticalAlignment="Bottom"
                                                    Command="{Binding DataContext.RemovePlaceholderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+ Add placeholder"
                                Style="{StaticResource OutlineButton}"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,0"
                                Command="{Binding AddPlaceholderCommand}" />

                        <Button Content="🗑 Delete template"
                                Style="{StaticResource OutlineButton}"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0"
                                Foreground="#E64646"
                                BorderBrush="#E64646"
                                Command="{Binding DeleteTemplateCommand}"
                                CommandParameter="{Binding SelectedTemplate}"
                                Visibility="{Binding SelectedTemplate.Id, Converter={x:Static vm:IntToVisibilityConverter.Instance}}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
