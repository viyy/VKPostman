<UserControl x:Class="VkPostman.Wpf.Views.PlaceholdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:PlaceholdersViewModel}"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- ===== List ===== -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Placeholders" Style="{StaticResource SectionHeader}" />
                    <Button Content="🏷 New placeholder"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding NewPlaceholderCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" TextTrimming="CharacterEllipsis">
                                    <Run Text="{}{{ " FontFamily="Cascadia Mono, Consolas" Foreground="#818C99" />
                                    <Run Text="{Binding Key, Mode=OneWay}" FontFamily="Cascadia Mono, Consolas" />
                                    <Run Text=" }}" FontFamily="Cascadia Mono, Consolas" Foreground="#818C99" />
                                </TextBlock>
                                <TextBlock Text="{Binding DisplayName, Mode=OneWay}" Style="{StaticResource MutedText}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ===== Editor ===== -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <Grid>
                <TextBlock Text="Pick a placeholder on the left, or click 'New placeholder'."
                           Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsEditing, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}" />

                <ScrollViewer Visibility="{Binding IsEditing, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="Placeholder" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock Text="{Binding Autosave.Status, Converter={x:Static vm:AutosaveStatusLabelConverter.Instance}}"
                                           Foreground="{StaticResource VkTextSecondaryBrush}"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"
                                           FontSize="12" />
                                <Button Content="Close" Style="{StaticResource OutlineButton}"
                                        Command="{Binding CloseEditorCommand}" />
                            </StackPanel>
                        </DockPanel>

                        <TextBlock Text="Key (referenced as {{ key }} in templates)" Margin="0,8,0,4" />
                        <TextBox Text="{Binding SelectedItem.Key, UpdateSourceTrigger=PropertyChanged}"
                                 FontFamily="Cascadia Mono, Consolas" />

                        <TextBlock Text="Display name" Margin="0,12,0,4" />
                        <TextBox Text="{Binding SelectedItem.DisplayName, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Type" Margin="0,12,0,4" />
                        <ComboBox ItemsSource="{Binding PlaceholderTypes}"
                                  SelectedItem="{Binding SelectedItem.Type, Mode=TwoWay}" />

                        <TextBlock Text="Description (optional)" Margin="0,12,0,4" />
                        <TextBox Text="{Binding SelectedItem.Description, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Default value (used when the draft leaves this field empty)" Margin="0,12,0,4" />
                        <TextBox Text="{Binding SelectedItem.DefaultValue, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Text="Used by" Style="{StaticResource SectionHeader}" Margin="0,16,0,4" />
                        <ItemsControl ItemsSource="{Binding UsedByTemplateNames}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Mode=OneWay}" Margin="0,2,0,0" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="(no templates reference this key)"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,2,0,0"
                                   Visibility="{Binding UsedByTemplateNames.Count, Converter={x:Static vm:ZeroToVisibilityConverter.Instance}}" />

                        <Button Content="🗑 Delete placeholder"
                                Style="{StaticResource OutlineButton}"
                                HorizontalAlignment="Left"
                                Margin="0,20,0,0"
                                Foreground="#E64646"
                                BorderBrush="#E64646"
                                Command="{Binding DeletePlaceholderCommand}"
                                CommandParameter="{Binding SelectedItem}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
