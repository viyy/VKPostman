<UserControl x:Class="VkPostman.Wpf.Views.GroupsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:GroupsViewModel}"
             mc:Ignorable="d">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Group list ===== -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Groups" Style="{StaticResource SectionHeader}" />
                    <Button Content="👥 Add group"
                            Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch"
                            Command="{Binding NewGroupCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <EventSetter Event="MouseDoubleClick" Handler="GroupDoubleClick" />
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Style="{StaticResource MutedText}">
                                    <Run Text="@" /><Run Text="{Binding ScreenName, Mode=OneWay}" />
                                    <Run Text="  ·  template: " />
                                    <Run Text="{Binding PostTemplate.Name, Mode=OneWay, FallbackValue=(none)}" />
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ===== Editor ===== -->
        <Border Grid.Column="1" Style="{StaticResource Card}">
            <Grid>
                <TextBlock Text="Pick a group on the left, or click 'Add group'."
                           Style="{StaticResource MutedText}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsEditing, Converter={x:Static vm:InverseBoolToVisibilityConverter.Instance}}" />

                <StackPanel Visibility="{Binding IsEditing, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                    <DockPanel>
                        <TextBlock Text="Group" Style="{StaticResource SectionHeader}" DockPanel.Dock="Left" />
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="💾 Save" Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,6,0" Command="{Binding SaveGroupCommand}" />
                            <Button Content="Cancel" Style="{StaticResource OutlineButton}"
                                    Command="{Binding CancelEditCommand}" />
                        </StackPanel>
                    </DockPanel>

                    <TextBlock Text="Display name" Margin="0,8,0,4" />
                    <TextBox Text="{Binding SelectedGroup.DisplayName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Screen name (@shortname or vk.com/shortname)" Margin="0,12,0,4" />
                    <TextBox Text="{Binding SelectedGroup.ScreenName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="VK community ID (negative — e.g. -12345). Optional." Margin="0,12,0,4" />
                    <TextBox Text="{Binding SelectedGroup.VkGroupId, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Template" Margin="0,12,0,4" />
                    <ComboBox ItemsSource="{Binding Templates}"
                              SelectedValue="{Binding SelectedGroup.PostTemplateId, Mode=TwoWay}"
                              SelectedValuePath="Id"
                              DisplayMemberPath="Name" />

                    <TextBlock Text="Mandatory tags (space-separated)" Margin="0,12,0,4" />
                    <TextBox Text="{Binding EditMandatoryTagsInput, UpdateSourceTrigger=PropertyChanged}" />

                    <CheckBox IsChecked="{Binding SelectedGroup.IsActive}" Content="Active" Margin="0,12,0,0" />

                    <TextBlock Text="Notes" Margin="0,12,0,4" />
                    <TextBox Text="{Binding SelectedGroup.Notes, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60"
                             VerticalScrollBarVisibility="Auto" />

                    <Button Content="🗑 Delete group"
                            Style="{StaticResource OutlineButton}"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0"
                            Foreground="#E64646"
                            BorderBrush="#E64646"
                            Command="{Binding DeleteGroupCommand}"
                            CommandParameter="{Binding SelectedGroup}"
                            Visibility="{Binding SelectedGroup.Id, Converter={x:Static vm:IntToVisibilityConverter.Instance}}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
