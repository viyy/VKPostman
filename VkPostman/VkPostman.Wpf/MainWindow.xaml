<Window x:Class="VkPostman.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
        Title="VK Postman"
        Height="780" Width="1200"
        MinHeight="520" MinWidth="900"
        Background="{StaticResource VkBgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        Foreground="{StaticResource VkTextBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource VkSurfaceBrush}"
                BorderBrush="{StaticResource VkBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource VkBlueBrush}"
                        Padding="18,16">
                    <TextBlock Text="✉ VK Postman"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold" />
                </Border>

                <StackPanel Margin="8,10,8,0">
                    <RadioButton Content="📝   Drafts"
                                 IsChecked="{Binding IsDraftsSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarNavButton}" />
                    <RadioButton Content="📄   Templates"
                                 IsChecked="{Binding IsTemplatesSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarNavButton}" />
                    <RadioButton Content="👥   Groups"
                                 IsChecked="{Binding IsGroupsSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarNavButton}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content area -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"
                        Margin="24,20" />
    </Grid>
</Window>
