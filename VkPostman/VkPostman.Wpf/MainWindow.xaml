<Window x:Class="VkPostman.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
        Title="VK Postman"
        Height="780" Width="1200"
        MinHeight="520" MinWidth="900"
        Background="{StaticResource VkBgBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        Foreground="{StaticResource VkTextBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource VkSurfaceBrush}"
                BorderBrush="{StaticResource VkBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource VkBlueBrush}"
                        Padding="18,16">
                    <TextBlock Text="✉ VK Postman"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold" />
                </Border>

                <!-- Data import/export anchored at the bottom of the sidebar. -->
                <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12">
                    <Separator Margin="0,8" />
                    <TextBlock Text="Data" Foreground="{StaticResource VkTextSecondaryBrush}"
                               FontSize="11" Margin="8,0,0,4" />
                    <Button Content="⬇   Export JSON"
                            HorizontalContentAlignment="Left"
                            Padding="12,8"
                            Margin="0,1"
                            BorderThickness="0"
                            Background="Transparent"
                            Cursor="Hand"
                            Command="{Binding ExportDataCommand}" />
                    <Button Content="⬆   Import JSON"
                            HorizontalContentAlignment="Left"
                            Padding="12,8"
                            Margin="0,1"
                            BorderThickness="0"
                            Background="Transparent"
                            Cursor="Hand"
                            Command="{Binding ImportDataCommand}" />
                </StackPanel>

                <StackPanel Margin="8,10,8,0">
                    <RadioButton Content="📝   Drafts"
                                 IsChecked="{Binding IsDraftsSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarNavButton}" />
                    <RadioButton Content="📄   Templates"
                                 IsChecked="{Binding IsTemplatesSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarNavButton}" />
                    <RadioButton Content="🏷   Placeholders"
                                 IsChecked="{Binding IsPlaceholdersSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarNavButton}" />
                    <RadioButton Content="👥   Groups"
                                 IsChecked="{Binding IsGroupsSelected, Mode=TwoWay}"
                                 Style="{StaticResource SidebarNavButton}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content column -->
        <DockPanel Grid.Column="1">
            <!-- Import/export banner -->
            <Border DockPanel.Dock="Top"
                    Visibility="{Binding IoMessage, Converter={x:Static vm:NotNullConverter.Instance}}"
                    Padding="16,10">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IoMessageIsError}" Value="True">
                                <Setter Property="Background" Value="#FCE4E4" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IoMessageIsError}" Value="False">
                                <Setter Property="Background" Value="#E6F4E6" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding IoMessage}" FontSize="13" />
            </Border>

            <ContentControl Content="{Binding CurrentView}"
                            Margin="24,20" />
        </DockPanel>
    </Grid>
</Window>
