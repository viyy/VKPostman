<Application x:Class="VkPostman.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VkPostman.Wpf.ViewModels"
             xmlns:v="clr-namespace:VkPostman.Wpf.Views">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Map each top-level ViewModel to its View so a ContentPresenter just works. -->
            <DataTemplate DataType="{x:Type vm:DraftsViewModel}">
                <v:DraftsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:GroupsViewModel}">
                <v:GroupsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:TemplatesViewModel}">
                <v:TemplatesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:PlaceholdersViewModel}">
                <v:PlaceholdersView />
            </DataTemplate>

            <!-- ================ Palette ================ -->
            <Color x:Key="VkBlue">#5181B8</Color>
            <Color x:Key="VkDarkBlue">#45719B</Color>
            <Color x:Key="VkBg">#EDEEF0</Color>
            <Color x:Key="VkSurface">#FFFFFF</Color>
            <Color x:Key="VkBorder">#E7E8EC</Color>
            <Color x:Key="VkText">#2C2D30</Color>
            <Color x:Key="VkTextSecondary">#818C99</Color>

            <SolidColorBrush x:Key="VkBlueBrush" Color="{StaticResource VkBlue}" />
            <SolidColorBrush x:Key="VkDarkBlueBrush" Color="{StaticResource VkDarkBlue}" />
            <SolidColorBrush x:Key="VkBgBrush" Color="{StaticResource VkBg}" />
            <SolidColorBrush x:Key="VkSurfaceBrush" Color="{StaticResource VkSurface}" />
            <SolidColorBrush x:Key="VkBorderBrush" Color="{StaticResource VkBorder}" />
            <SolidColorBrush x:Key="VkTextBrush" Color="{StaticResource VkText}" />
            <SolidColorBrush x:Key="VkTextSecondaryBrush" Color="{StaticResource VkTextSecondary}" />

            <!-- ================ Controls ================ -->
            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="Background" Value="{StaticResource VkBlueBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="12,6" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource VkDarkBlueBrush}" />
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter Property="Opacity" Value="0.55" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="Button" x:Key="OutlineButton" BasedOn="{StaticResource PrimaryButton}">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource VkBlueBrush}" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{StaticResource VkBlueBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#E8F0F8" />
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="BorderBrush" Value="#D3D9DE" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Background" Value="White" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Padding" Value="6,4" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style TargetType="TextBlock" x:Key="SectionHeader">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Foreground" Value="{StaticResource VkTextBrush}" />
            </Style>

            <Style TargetType="TextBlock" x:Key="MutedText">
                <Setter Property="Foreground" Value="{StaticResource VkTextSecondaryBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style TargetType="Border" x:Key="Card">
                <Setter Property="Background" Value="{StaticResource VkSurfaceBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource VkBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <Style x:Key="SidebarNavButton" TargetType="RadioButton">
                <Setter Property="GroupName" Value="Sidebar" />
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd"
                                    CornerRadius="6"
                                    Padding="{TemplateBinding Padding}"
                                    Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Left"
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#F4F5F7" />
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#E8F0F8" />
                                    <Setter Property="Foreground" Value="{StaticResource VkBlueBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
